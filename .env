# G0DM0D3 Environment Configuration
# ====================================

# REQUIRED: Your OpenRouter API key (get one at https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# OPTIONAL: API authentication key (if unset, API is open/unauthenticated)
# GODMODE_API_KEY=your-secret-key

# OPTIONAL: Multiple API keys (comma-separated)
# GODMODE_API_KEYS=key1,key2,key3

# OPTIONAL: Tier assignments (enterprise:key1,pro:key2)
# GODMODE_TIER_KEYS=enterprise:key1,pro:key2

# Server config
PORT=7860
CORS_ORIGIN=*

# Frontend static server port
FRONTEND_PORT=8000

# OPTIONAL: HuggingFace dataset publishing
# HF_TOKEN=hf_...
# HF_DATASET_REPO=your-username/g0dm0d3
